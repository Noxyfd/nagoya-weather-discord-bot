# Discord bot token
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel ID where the message should be posted
DISCORD_CHANNEL_ID=your_channel_id_here

# Defaults are already set for Nagoya
WEATHER_LOCATION_NAME=Nagoya
WEATHER_LATITUDE=35.1815
WEATHER_LONGITUDE=136.9066
WEATHER_TIMEZONE=Asia/Tokyo

# Cloudflare Worker manual test endpoint token
ADMIN_TOKEN=your_admin_token_here

# Earthquake reports older than this are ignored by the Cloudflare Worker
EARTHQUAKE_MAX_REPORT_AGE_MINUTES=360
